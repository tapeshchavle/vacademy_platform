[Unit]
Description=Vacademy BBB Heal Service (on-demand recording pipeline recovery)
After=network.target

[Service]
Type=simple
EnvironmentFile=/etc/bigbluebutton/vacademy-recording.conf
ExecStart=/usr/bin/python3 /usr/local/bin/bbb-heal-service.py
Restart=on-failure
RestartSec=5
User=root
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
