# HTTP Headers for Cloudflare Pages
# This file configures HTTP headers for the frontend application

# ============================================
# Iframe Embedding Configuration for Forms
# ============================================
# Allow audience response forms to be embedded in iframes
# This is required for the "Embed Code" feature in Admin Dashboard
# Note: Specific routes MUST be placed before the general /* rule

/audience-response
  X-Frame-Options: ALLOWALL
  Content-Security-Policy: frame-ancestors 'self' https://*.vacademy.io https://admin.vacademy.io https://admin-stage.vacademy.io *
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

/audience-response/*
  X-Frame-Options: ALLOWALL
  Content-Security-Policy: frame-ancestors 'self' https://*.vacademy.io https://admin.vacademy.io https://admin-stage.vacademy.io *
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# ============================================
# Security Headers for All Other Pages
# ============================================
# Keep strict security for all other pages

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: no-referrer-when-downgrade
  Cross-Origin-Opener-Policy: same-origin-allow-popups

# Additional security headers for HTML pages
/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

# Static assets caching
/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.jpeg
  Cache-Control: public, max-age=31536000, immutable

/*.gif
  Cache-Control: public, max-age=31536000, immutable

/*.ico
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable

/*.webp
  Cache-Control: public, max-age=31536000, immutable

/*.woff
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/*.ttf
  Cache-Control: public, max-age=31536000, immutable

/*.eot
  Cache-Control: public, max-age=31536000, immutable

# Service worker and manifest - no cache
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

/service-worker.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

/firebase-messaging-sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

/firebase-messaging-sw.seven_cs.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

/manifest.webmanifest
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
